# Reduce noisy 404s from CMS vulnerability scanners (302 → home)
/wp-admin https://perfectfitme.com/ 302
/wp-login.php https://perfectfitme.com/ 302
/xmlrpc.php https://perfectfitme.com/ 302
/wp-admin/* https://perfectfitme.com/ 302
/wp-content/* https://perfectfitme.com/ 302
/wp-includes/* https://perfectfitme.com/ 302

# Legal / trust pages: explicit 301 (Cloudflare also strips .html with 308)
/privacy.html /privacy 301
/terms.html /terms 301
/contact.html /contact 301
/about.html /about 301
/editorial-standards.html /editorial-standards 301
/how-it-works.html /how-it-works 301

# Canonical demo page URL
/demo-video /demo-video.html 301

# Browsers default favicon path → actual asset
/favicon.ico /favicon-32x32.png 302
